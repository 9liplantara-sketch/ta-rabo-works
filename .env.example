# サーバー側（Vercel）のみ。lab_manager.html や git にコミットしないこと。
# ローカル: cp .env.example .env
# Vercel: Project → Settings → Environment Variables

# ── Neon ──────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# ── Google OAuth（Google Cloud Console）────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 例: https://あなたのプロジェクト.vercel.app/api/auth/callback
GOOGLE_REDIRECT_URI=

# ── セッション署名（32文字以上のランダム文字列）──
JWT_SECRET=

# ── 教員メール（カンマ区切り・students 未登録でも admin ログイン可）
ADMIN_EMAILS=your-teacher@gmail.com

# ── フロント URL（OAuth 完了後の戻り先）
FRONTEND_URL=https://9liplantara-sketch.github.io/ta-rabo-works

# ── CORS（カンマ区切り）
API_ALLOWED_ORIGINS=https://9liplantara-sketch.github.io,http://localhost:8765

# ── 公開してよい API のベース URL（フロント用・任意）
API_BASE_URL=https://あなたのプロジェクト.vercel.app
